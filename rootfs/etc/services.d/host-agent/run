#!/command/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

# shellcheck source=/dev/null
. /opt/signoz-aio/lib/env.sh
normalize_blank_env "${AIO_BLANK_AS_UNSET_VARS[@]}"

HOST_AGENT_CONFIG="/appdata/config/generated-host-agent.yaml"
HOST_AGENT_STATUS="/appdata/config/generated-host-agent.status"
COLLECTOR_BIN="/opt/signoz-otel-collector/signoz-otel-collector"

if ! is_true "${SIGNOZ_ENABLE_HOST_AGENT:-false}"; then
    echo "[signoz-aio] Local host agent disabled."
    exec sleep infinity
fi

if [[ ! -f "${HOST_AGENT_CONFIG}" ]]; then
    echo "[signoz-aio] Local host agent enabled, but no compatible host sources were detected."
    if [[ -f "${HOST_AGENT_STATUS}" ]]; then
        read -r host_agent_status <"${HOST_AGENT_STATUS}" || host_agent_status="unknown"
        echo "[signoz-aio] Host agent status: ${host_agent_status}"
    fi
    exec sleep infinity
fi

until bash -lc 'exec 3<>/dev/tcp/127.0.0.1/4317' >/dev/null 2>&1; do
    sleep 2
done

echo "[signoz-aio] Starting local host agent collector."
exec "${COLLECTOR_BIN}" --config "${HOST_AGENT_CONFIG}"
